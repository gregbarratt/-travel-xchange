# App - update this to the live domain before production deployment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase - required for login, database, storage, and member features
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=server-only-never-share-in-browser

# Stripe - required when paid memberships and billing go live
# STRIPE_SECRET_KEY can be a full secret key starting sk_test_ or a restricted key starting rk_test_.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_PROFESSIONAL=
STRIPE_PRICE_SUPPLIER_BASIC=
STRIPE_PRICE_SUPPLIER_PRO=
STRIPE_PRICE_RECRUITER=
STRIPE_PRICE_ADVERTISER=

# Email and notifications - recommended before inviting real users
EMAIL_FROM=
NOTIFICATION_PROVIDER=
